{
  "entryPoints": ["../src/index.ts"],
  "tsconfig": "../tsconfig.json",
  "plugin": ["typedoc-plugin-markdown"],
  "out": "api",
  "entryFileName": "index.md",
  "hidePageTitle": true,
  "readme": "none",
  "excludePrivate": true,
  "excludeInternal": true,
  "excludeExternals": true,
  "categorizeByGroup": true,
  "sort": ["source-order"]
}